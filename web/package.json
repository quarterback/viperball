{
  "name": "viperball-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "React + Mantine SPA for the Viperball simulation workbench",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:api": "openapi-typescript http://localhost:8080/openapi.json -o src/api/schema.ts"
  },
  "dependencies": {
    "@mantine/core": "^7.13.4",
    "@mantine/dates": "^7.13.4",
    "@mantine/hooks": "^7.13.4",
    "@mantine/notifications": "^7.13.4",
    "@mantine/spotlight": "^7.13.4",
    "@tabler/icons-react": "^3.21.0",
    "@tanstack/react-query": "^5.59.16",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "mantine-react-table": "^2.0.0-beta.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "openapi-typescript": "^7.4.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
