# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Testing
.pytest_cache/
.coverage
htmlcov/

# Dynasty saves (test data)
dynasty_save.json
*.dynasty.json

# Database files (user-specific state)
*.db
*.db-wal
*.db-shm

# Config with API keys (user-specific)
config.json

# Claude Code local settings (may contain API keys)
.claude/settings.local.json

# web/ is a JS/TS app — the Python-style ignores above (lib/, build/, dist/, var/…)
# must not silently swallow its SOURCE. node_modules/dist live at web/ root and are
# governed by web/.gitignore, so this only un-ignores real source under web/src/.
!web/src/
!web/src/**
